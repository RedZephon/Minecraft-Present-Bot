# MC Presence — Environment Configuration
# Copy this file to .env and fill in your values.

# Minecraft server to connect bots to
MC_HOST=play.example.net
MC_PORT=25565

# Web dashboard port
WEB_PORT=3100

# Anthropic API key (required for AI chat modes)
ANTHROPIC_API_KEY=

# CobbleBridge plugin connection (optional)
BRIDGE_URL=http://localhost:3101
BRIDGE_SECRET=changeme

# Discord webhook for forwarding bot messages (optional)
DISCORD_WEBHOOK=

# Your Minecraft username (used for admin commands in AI chat)
OWNER_USERNAME=
